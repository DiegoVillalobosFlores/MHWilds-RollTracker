{
  "name": "mhwildsartiantracker",
  "module": "index.ts",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "bun run --watch index.ts",
    "server": "bun run --watch server.tsx",
    "compile:linux:modern": "bun build --compile --target=bun-linux-x64-modern --minify ./index.ts --outfile mhwilds-tracker",
    "compile:server:linux:modern": "bun build --compile --target=bun-linux-x64-modern --minify ./server.tsx --outfile mhwilds-tracker-server"
  },
  "devDependencies": {
    "@types/bun": "latest"
  },
  "peerDependencies": {
    "typescript": "^5"
  }
}
